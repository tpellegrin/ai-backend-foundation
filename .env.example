# Application
APP_ENV=development
LOG_LEVEL=info

# Database
# Example: postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379/0
ARQ_REDIS_URL=redis://localhost:6379/1

# Auth
# Generate keys: ssh-keygen -t rsa -b 4096 -m PEM -f jwt.key
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ISSUER=ai-backend-foundation
JWT_AUDIENCE=ai-backend-foundation

# AI Providers
OPENAI_API_KEY=sk-placeholder
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AI Governance
LLM_MONTHLY_BUDGET_USD=100.0
LLM_MODEL_ALLOWLIST=gpt-4o,gpt-4o-mini,text-embedding-3-small

# Storage
# Phase 2: 'local' only
BLOB_STORAGE_BACKEND=local
BLOB_LOCAL_DIR=./.storage

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
