# Application
APP_ENV=development
LOG_LEVEL=info
# Database
# Example: postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
# Redis
REDIS_URL=redis://localhost:6379/0
ARQ_REDIS_URL=redis://localhost:6379/1
# Auth
# Generate keys: ssh-keygen -t rsa -b 4096 -m PEM -f jwt.key
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ISSUER=ai-backend-foundation
JWT_AUDIENCE=ai-backend-foundation
# Argon2
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=19456
ARGON2_PARALLELISM=1
ARGON2_HASH_LEN=32
ARGON2_SALT_LEN=16
# AI Providers
OPENAI_API_KEY=sk-placeholder
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# AI Governance
LLM_MONTHLY_BUDGET_USD=100.0
LLM_MODEL_ALLOWLIST=gpt-4o,gpt-4o-mini,text-embedding-3-small
# Storage
# Phase 2: 'local' only
BLOB_STORAGE_BACKEND=local
BLOB_LOCAL_DIR=./.storage
# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# HTTP client (T-703 shared AsyncClient)
HTTP_CONNECT_TIMEOUT_S=5.0
HTTP_READ_TIMEOUT_S=30.0
HTTP_TOTAL_TIMEOUT_S=60.0
HTTP_RETRY_MAX_ATTEMPTS=3
HTTP_RETRY_BACKOFF_FACTOR=0.5
# Arq worker (T-1401 adapter / T-1402 worker entrypoint)
ARQ_QUEUE_NAME=default
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT_S=300
ARQ_KEEP_RESULT_S=3600
# API (CORS + security headers; deny-by-default)
API_CORS_ALLOWED_ORIGINS=
API_CORS_ALLOW_CREDENTIALS=false
API_CORS_ALLOWED_METHODS=GET,POST
API_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
API_SECURITY_HEADERS_ENABLED=true
