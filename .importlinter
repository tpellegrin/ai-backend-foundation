[importlinter]
root_packages =
    app

# NOTE: Missing future packages are represented as optional layers using
# parentheses (e.g. (app.main)) in the 'layers' contract.
# For 'independence' and 'forbidden' contracts, recursive wildcards (e.g.
# app.module.**) are used to allow the contracts to pass even when modules
# do not yet exist.
# Future ignore_imports entries must be added only when the matching import
# actually exists. Dummy imports and dummy package markers are strictly forbidden.

[importlinter:contract:layers]
name = Layers
type = layers
# NOTE: The `Layers` contract governs the layered core and entrypoints only.
# `app.infrastructure` is modeled as an outer driven-adapter ring (ADR-0026)
# and is governed by explicit boundary contracts below.
layers =
    (app.main)
    (app.api)
    (app.core)
    (app.auth) | (app.users) | (app.documents) | (app.rag) | (app.ai) | (app.ai_governance)
    (app.llm) | (app.embeddings) | (app.prompts)
    app.platform
    app.observability
    app.shared
ignore_imports =
    app.users.api -> app.auth.deps
    app.users.api -> app.auth.domain

[importlinter:contract:capabilities-independent]
name = Capabilities are independent
type = independence
modules =
    app.llm.**
    app.embeddings.**
    app.prompts.**

[importlinter:contract:ai-rag-independent]
name = ai and rag are independent
type = independence
modules =
    app.ai.**
    app.rag.**

[importlinter:contract:auth-no-users]
name = auth does not import users
type = forbidden
source_modules =
    app.auth.**
forbidden_modules =
    app.users.**

[importlinter:contract:core-wiring-only-infra]
name = Only core.wiring imports infrastructure
type = forbidden
source_modules =
    app.shared.**
    app.observability.**
    app.platform.**
    app.llm.**
    app.embeddings.**
    app.prompts.**
    app.auth.**
    app.users.**
    app.documents.**
    app.rag.**
    app.ai.**
    app.ai_governance.**
    app.api.**
    app.main.**
    app.core.lifespan
    app.core.container
    app.core.config.**
    app.core.di
    app.core.tests.**
forbidden_modules =
    app.infrastructure.**
# Direct-import semantics (see ADR-0025, ADR-0026). This forbidden contract
# enforces the direct-import ban only: no source module listed above may write
# a direct `from app.infrastructure...` import. The sanctioned composition flow
# `app.main -> app.core.lifespan -> app.core.wiring.<x> -> app.infrastructure.<x>`
# (ADR-0023) is a transitive path and is not a violation. Dynamic imports
# (`importlib.import_module`) or re-export shims used to hide a wiring edge
# from static analysis are forbidden — see rules.md §1 and review.md §2.
# `app.core.wiring.**` is intentionally omitted from `source_modules` as it
# is the sanctioned binding surface.
allow_indirect_imports = True

[importlinter:contract:infrastructure-boundary]
name = Infrastructure adapter-ring boundary
type = forbidden
source_modules =
    app.infrastructure.**
forbidden_modules =
    app.main.**
    app.api.**
    app.core.**
# ADR-0026: Infrastructure adapters (driven) live outside the core stack;
# they implement ports and import them, but they must never import the
# application entrypoints or core composition logic (except transitively
# via wiring, which is not handled by this direct-import contract).
# Adapters are allowed to import shared, observability, and port-owning
# modules below core.
allow_indirect_imports = True

[importlinter:contract:adapters-independent]
name = Infrastructure adapters are independent
type = independence
modules =
    app.infrastructure.db.**
    app.infrastructure.redis.**
    app.infrastructure.storage.**
    app.infrastructure.queue.**
    app.infrastructure.llm_providers.**
    app.infrastructure.embedding_providers.**
    app.infrastructure.vector_stores.**
# ADR-0026: Adapters should not import other adapters. Cross-adapter
# composition belongs in `app.core.wiring.*`.

[importlinter:contract:platform-bottom]
name = Platform is below everything except shared
type = forbidden
source_modules =
    app.platform.**
forbidden_modules =
    app.infrastructure.**
    app.llm.**
    app.embeddings.**
    app.prompts.**
    app.auth.**
    app.users.**
    app.documents.**
    app.rag.**
    app.ai.**
    app.ai_governance.**
    app.api.**
    app.core.**
    app.main.**

# Contract 7: No cross-module persistence/adapters imports
[importlinter:contract:no-cross-persistence]
name = No cross-module persistence/adapters imports
type = forbidden
source_modules =
    app.**
forbidden_modules =
    app.auth.persistence.**
    app.users.persistence.**
    app.documents.persistence.**
    app.rag.persistence.**
    app.ai.persistence.**
    app.ai_governance.persistence.**
    app.auth.adapters.**
    app.ai.tools.**
    app.ai.memory.**
allow_indirect_imports = True
ignore_imports =
    app.core.wiring.auth -> app.auth.adapters.**

# NOTE: Future ignore_imports exceptions must be added only when the matching
# import actually exists. Each exception must be justified by the dependency
# graph / ADR. Unmatched exceptions are forbidden because Import Linter treats
# them as config errors.
# ignore_imports =
#     app.auth.* -> app.auth.persistence
#     app.users.* -> app.users.persistence
#     app.documents.* -> app.documents.persistence
#     app.rag.* -> app.rag.persistence
#     app.ai.* -> app.ai.persistence
#     app.ai_governance.* -> app.ai_governance.persistence
#     app.auth.* -> app.auth.adapters
#     app.ai.* -> app.ai.tools
#     app.ai.* -> app.ai.memory
#     app.core.wiring.* -> *
#     alembic.* -> *
